\",\"9999\",\"static/chunks/9999-8fc54d9dd072d4ec.js\",\"7737\",\"static/chunks/7737-54f4cb9ed60a7229.js\",\"7177\",\"stati"])</script><script>self.__next_f.push([1,"c/chunks/app/layout-032c04744fd2213f.js\"],\"default\"]\n11:I[59665,[],\"MetadataBoundary\"]\n13:I[59665,[],\"OutletBoundary\"]\n16:I[74911,[],\"AsyncMetadataOutlet\"]\n18:I[59665,[],\"ViewportBoundary\"]\n1a:I[26614,[],\"\"]\n1b:I[74911,[],\"AsyncMetadata\"]\n:HL[\"/_next/static/media/4cf2300e9c8272f7-s.p.woff2\",\"font\",{\"crossOrigin\":\"\",\"type\":\"font/woff2\"}]\n:HL[\"/_next/static/css/66d9b76a8f6a415c.css\",\"style\"]\n:HL[\"/_next/static/css/a26a1f314ae342b0.css\",\"style\"]\n2:T1077,"])</script><script>self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"O que é Vibe Coding?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Vibe Coding é uma metodologia de desenvolvimento onde você constrói aplicações e resolve problemas através de uma conversa estratégica com a Inteligência Artificial. Em vez de escrever código linha por linha, você atua como um arquiteto, guiando a IA para que ela execute a programação. É a forma mais rápida e poderosa de criar tecnologia hoje, e é o que ensinamos no Cultura Builder.\"}},{\"@type\":\"Question\",\"name\":\"Preciso saber programar para fazer o curso?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Não. O Cultura Builder foi desenhado para não-técnicos. 70% dos nossos alunos vêm de áreas como direito, marketing, design e administração. Ensinamos a lógica e a estratégia para você construir com IA, independentemente do seu background.\"}},{\"@type\":\"Question\",\"name\":\"Quanto custa e quais são as formas de pagamento?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"O acesso completo por um ano custa R$ 2.998,00, que pode ser parcelado em até 12x de R$ 249,83 sem juros no cartão de crédito. Também aceitamos pagamento à vista via Pix e criptomoedas.\"}},{\"@type\":\"Question\",\"name\":\"Como funciona a garantia de 7 dias?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Você pode se inscrever e ter acesso total à plataforma por 7 dias. Se por qualquer motivo achar que não é para você, basta solicitar o cancelamento dentro desse período e nós devolvemos 100% do seu investimento, sem perguntas.\"}},{\"@type\":\"Question\",\"name\":\"Os R$ 20.000 em créditos são realmente gratuitos?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. Através de nossas parcerias exclusivas com gigantes como AWS, NVIDIA e outras, você recebe vouchers e acessos que somam mais de R$ 20.000 para usar na infraestrutura dos seus projetos. O objetivo é que você possa construir e experimentar sem se preocupar com custos.\"}},{\"@type\":\"Question\",\"name\":\"Como funciona a certificação blockchain?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ao concluir o curso, você recebe uma certificação registrada na blockchain, o que significa que ela é imutável, verificável e reconhecida globalmente. Qualquer pessoa pode verificar a autenticidade do seu certificado através de um link público, sem depender de uma instituição centralizada. É o diploma do futuro.\"}},{\"@type\":\"Question\",\"name\":\"Quem são os mentores e qual a experiência deles?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Nossos mentores são executivos e fundadores que trabalham ou trabalharam em empresas Fortune 500 como Samsung, Microsoft, Nestlé e L'Oréal. Eles não são apenas professores, mas profissionais ativos no mercado que estão na linha de frente da revolução da IA e blockchain.\"}},{\"@type\":\"Question\",\"name\":\"Os créditos de IA expiram?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Os créditos têm validade conforme as políticas de cada parceiro (geralmente 12 meses). O importante é que você terá recursos suficientes para construir diversos projetos durante todo o seu período de acesso ao curso sem se preocupar com custos de infraestrutura.\"}},{\"@type\":\"Question\",\"name\":\"Como posso verificar minha certificação?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Cada certificado possui um ID único registrado na blockchain. Você receberá um link de verificação que pode ser compartilhado com empregadores, clientes ou em seu LinkedIn. Qualquer pessoa pode verificar a autenticidade instantaneamente, sem intermediários.\"}},{\"@type\":\"Question\",\"name\":\"Quanto tempo de acesso eu tenho?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"O plano garante acesso completo por 1 ano (12 meses). Após esse período, você pode renovar sua assinatura para continuar tendo acesso à comunidade, às novas aulas e às mentorias.\"}},{\"@type\":\"Question\",\"name\":\"Terei suporte durante o curso?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Sim. O suporte é um dos nossos pilares. Você terá acesso à comunidade exclusiva para tirar dúvidas com builders e mentores, além de poder interagir diretamente com os instrutores nas mentorias semanais ao vivo.\"}}]}"])</script><script>self.__next_f.push([1,"3:T993,"])</script><script>self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"Course\",\"name\":\"Vibe Coding: Do Zero ao Avançado\",\"description\":\"Aprenda a criar aplicações com Inteligência Artificial na prática. Domine o Vibe Coding, mesmo sem saber programar. Inclui certificação blockchain, R$ 20.000 em créditos AWS/NVIDIA e mentorias com executivos Fortune 500.\",\"provider\":{\"@type\":\"EducationalOrganization\",\"name\":\"Cultura Builder\",\"url\":\"https://www.culturabuilder.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://www.culturabuilder.com/logo.png\"},\"sameAs\":[\"https://x.com/culturabuilder\",\"https://www.linkedin.com/company/culturabuilder\",\"https://www.instagram.com/culturabuilder/\"]},\"image\":\"https://www.culturabuilder.com/og.png\",\"url\":\"https://www.culturabuilder.com\",\"offers\":{\"@type\":\"Offer\",\"category\":\"Paid\",\"price\":\"2998.00\",\"priceCurrency\":\"BRL\",\"availability\":\"https://schema.org/InStock\",\"url\":\"https://hub.culturabuilder.com\",\"validFrom\":\"2024-01-01\",\"priceValidUntil\":\"2026-12-31\",\"seller\":{\"@type\":\"Organization\",\"name\":\"Cultura Builder\"}},\"hasCourseInstance\":{\"@type\":\"CourseInstance\",\"courseMode\":\"online\",\"courseWorkload\":\"P12M\",\"instructor\":[{\"@type\":\"Person\",\"name\":\"Mentores Fortune 500\",\"description\":\"Executivos e fundadores de empresas como Samsung, Microsoft, Nestlé e L'Oréal\"}]},\"educationalLevel\":\"Beginner to Advanced\",\"timeRequired\":\"P12M\",\"inLanguage\":\"pt-BR\",\"availableLanguage\":\"pt-BR\",\"teaches\":[\"Vibe Coding\",\"Inteligência Artificial\",\"Desenvolvimento de Aplicações com IA\",\"Prompt Engineering\",\"Criação de Apps sem Programação\",\"ChatGPT para Desenvolvimento\"],\"coursePrerequisites\":\"Nenhum conhecimento prévio em programação necessário\",\"occupationalCredentialAwarded\":{\"@type\":\"EducationalOccupationalCredential\",\"name\":\"Certificação em Blockchain: Inteligência Artificial\",\"description\":\"Certificação registrada na blockchain, imutável e verificável globalmente\",\"credentialCategory\":\"certificate\",\"recognizedBy\":{\"@type\":\"Organization\",\"name\":\"Cultura Builder\"}},\"financialAid\":{\"@type\":\"MonetaryGrant\",\"name\":\"Créditos de IA inclusos\",\"amount\":{\"@type\":\"MonetaryAmount\",\"currency\":\"BRL\",\"value\":\"20000\"},\"description\":\"R$ 20.000 em créditos AWS e NVIDIA inclusos para construir seus projetos\"},\"hasCourseOutcome\":[{\"@type\":\"EducationalOccupationalCredential\",\"name\":\"Certificação Blockchain\"},{\"@type\":\"Thing\",\"name\":\"Criação de aplicações com IA\"},{\"@type\":\"Thing\",\"name\":\"Portfolio de projetos reais\"}]}"])</script><script>self.__next_f.push([1,"4:T760,{\"@context\":\"https://schema.org\",\"@type\":\"Offer\",\"name\":\"Plano Premium Completo - Cultura Builder\",\"description\":\"Acesso ilimitado por 1 ano ao eco